# ---------- Foundry / contracts ----------
contracts/lib/
contracts/out/
contracts/cache/
contracts/broadcast/
contracts/.env

# Keep broadcast dry-run and real deployment logs out of git; if you
# later want to track real testnet/mainnet deployments, unignore the
# specific chain-id folder you care about, e.g.:
# !contracts/broadcast/Deploy.s.sol/11155111/

# ---------- Frontend / Vite ----------
frontend/node_modules/
frontend/dist/
frontend/dist-ssr/
frontend/.env.local
frontend/.env.*.local
frontend/*.local

# Auto-generated ABIs (regenerated by scripts/deploy.sh on every run)
frontend/src/lib/generated/*.json

# ---------- Logs ----------
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ---------- Editors / OS ----------
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?